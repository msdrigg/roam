# Copy to /etc/roam-symbolicator/env and fill in real values.
# This file holds only the env vars the worker actually consumes; the rest of
# the RoamCli args have safe defaults for worker mode.

# Activate worker mode (equivalent to running with --symbolicate).
SYMBOLICATE=true

# Where the worker stores its dSYM cache + downloaded dyld_shared_cache files.
# Plan for ~20 GB free; system caches per OS build are 1-3 GB each.
DATA_DIR=/var/lib/roam-symbolicator/data

# Public backend the worker leases payloads from.
BACKEND_URL=https://backend.roam.msd3.io
BACKEND_API_KEY=replace-me

# Tuning knobs.
SYMBOLICATE_BATCH_SIZE=5
SYMBOLICATE_IDLE_SECONDS=600

# Logs.
RUST_LOG=info,roam_backend=info

# `ipsw` must be on the PATH for system-symbol downloads. Install via:
#   curl -L https://github.com/blacktop/ipsw/releases/download/<ver>/ipsw_<ver>_<os>_<arch>.tar.gz | tar -xz -C /usr/local/bin ipsw
