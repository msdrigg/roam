        "NSLocalNetworkUsageDescription": {
            "comment": "Privacy - Local Network Usage Description",
            "extractionState": "extracted_with_value",
            "localizations": {
                "ar": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "يستخدم روام الشبكة المحلية لاكتشاف والتحكم في تلفزيون Roku الخاص بك"
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Roam verwendet das lokale Netzwerk, um Ihren Roku-Fernseher zu entdecken und zu steuern"
                    }
                },
                "en": {
                    "stringUnit": {
                        "state": "new",
                        "value": "Roam uses the local network to discover and control your Roku TV"
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Roam usa la red local para descubrir y controlar su televisor Roku"
                    }
                },
                "es-419": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Roam usa la red local para descubrir y controlar su televisor Roku"
                    }
                },
                "fil": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Gumagamit ang Roam ng lokal na network upang matuklasan at kontrolin ang iyong Roku TV"
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Roam utilise le réseau local pour découvrir et contrôler votre téléviseur Roku"
                    }
                },
                "fr-CA": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Roam utilise le réseau local pour découvrir et contrôler votre téléviseur Roku"
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Roam utilizza la rete locale per scoprire e controllare il tuo Roku TV"
                    }
                },
                "pa": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "ਰੋਮ ਤੁਹਾਡੇ ਰੋਕੂ ਟੀਵੀ ਨੂੰ ਖੋਜਣ ਅਤੇ ਕੰਟਰੋਲ ਕਰਨ ਲਈ ਸਥਾਨਕ ਨੈੱਟਵਰਕ ਦੀ ਵਰਤੋਂ ਕਰਦਾ ਹੈ"
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Roam usa a rede local para descobrir e controlar sua TV Roku"
                    }
                },
                "pt-PT": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Roam usa a rede local para descobrir e controlar sua TV Roku"
                    }
                },
                "vi": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Roam sử dụng mạng cục bộ để khám phá và điều khiển Roku TV của bạn"
                    }
                },
                "zh-Hans": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Roam 使用本地网络来发现和控制您的 Roku 电视"
                    }
                }
            }
        },
