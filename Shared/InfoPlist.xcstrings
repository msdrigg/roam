                    }
                },
                "vi": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Mô tả sử dụng thêm thư viện ảnh"
                    }
                },
                "zh-Hans": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "添加到照片库使用描述"
                    }
                }
            }
        },
        "NSUserNotificationUsageDescription": {
            "comment": "Notification Usage Description",
            "extractionState": "manual",
            "localizations": {
                "ar": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "يمكن أن يخطر روامك عندما يستجيب المطور لرسالتك"
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Roam kann Sie benachrichtigen, wenn der Entwickler auf Ihre Nachricht antwortet"
                    }
                },
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Roam can notify you when the the developer responds to your message"
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Roam puede notificarle cuando el desarrollador responda a su mensaje"
                    }
                },
                "es-419": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Roam puede notificarle cuando el desarrollador responda a su mensaje"
                    }
                },
                "fil": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Maaaring abisuhan ka ng Roam kapag tumugon ang developer sa iyong mensahe"
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Roam peut vous notifier lorsque le développeur répond à votre message"
                    }
                },
                "fr-CA": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Roam peut vous notifier lorsque le développeur répond à votre message"
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Roam può notificarti quando lo sviluppatore risponde al tuo messaggio"
                    }
                },
                "pa": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "ਜਦੋਂ ਡਿਵੈਲਪਰ ਤੁਹਾਡੇ ਸੁਨੇਹੇ ਦਾ ਜਵਾਬ ਦੇਂਦਾ ਹੈ ਤਾਂ ਰੋਮ ਤੁਹਾਨੂੰ ਸੂਚਿਤ ਕਰ ਸਕਦਾ ਹੈ"
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "O Roam pode notificá-lo quando o desenvolvedor responder à sua mensagem"
                    }
                },
                "pt-PT": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "O Roam pode notificá-lo quando o desenvolvedor responder à sua mensagem"
                    }
                },
                "vi": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Roam có thể thông báo cho bạn khi nhà phát triển trả lời tin nhắn của bạn"
                    }
                },
                "zh-Hans": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "当开发者回复您的消息时，Roam 可以通知您"
                    }
                }
            }
        }
    },
    "version": "1.0"
}