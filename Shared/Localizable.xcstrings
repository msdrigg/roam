        "pa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'ਲੋਕਲ ਨੈਟਵਰਕ ਅਨੁਮਤੀ ਨਾ ਦਿੱਤੀ ਜਾਵੇ ਤੇ ਹੋ ਸਕਦਾ ਹੈ। ਕਿਰਪਾ ਕਰਕੇ ਸਿਸਟਮ ਸੈਟਿੰਗਜ਼ ਖੋਲ੍ਹੋ ਅਤੇ ਪ੍ਰਾਈਵੇਸੀ ਅਤੇ ਸੁਰੱਖਿਆ -> ਲੋਕਲ ਨੈਟਵਰਕ ਤੇ ਨੈਵੀਗੇਟ ਕਰੋ ਅਤੇ Roam ਲਈ ਐਕਸੈਸ ਯੋਗ ਕਰੋ'"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A permissão para rede local pode não estar concedida. Por favor, abra as Configurações do Sistema e vá até Privacidade e Segurança -> Rede Local e habilite o acesso para Roam."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
