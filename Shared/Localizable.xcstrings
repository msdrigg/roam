          "stringUnit" : {
            "state" : "translated",
            "value" : "Nenhuma conexão WiFi válida detectada. Pode estar conectado a um hotspot em vez da sua rede WiFi doméstica."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Không phát hiện được kết nối WiFi hợp lệ. Bạn có thể đang kết nối với điểm phát sóng thay vì mạng WiFi nhà bạn"
