        },
        "pa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Roam ਦਾ ਸੰਭਾਲਿਆ ਡਾਟਾ ਇਸ ਵੇਲੇ ਲਿਖਿਆ ਨਹੀਂ ਜਾ ਸਕਦਾ। ਡਿਵਾਈਸ ਕੰਟਰੋਲ ਹਾਲੇ ਵੀ ਕੰਮ ਕਰਦਾ ਹੈ, ਪਰ ਤਬਦੀਲੀਆਂ ਸੰਭਾਲੀਆਂ ਨਹੀਂ ਜਾ ਸਕਦੀਆਂ।"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os dados salvos do Roam não podem ser gravados no momento. O controle do dispositivo ainda funciona, mas as alterações podem não ser salvas."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os dados guardados do Roam não podem ser gravados neste momento. O controlo do dispositivo continua a funcionar, mas as alterações poderão não ser guardadas."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dữ liệu đã lưu của Roam hiện không thể được ghi. Tính năng điều khiển thiết bị vẫn hoạt động, nhưng các thay đổi có thể không được lưu."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
