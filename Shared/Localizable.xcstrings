    "Additinoally, WatchOS prevents us from discovering TV's on the local network." : {
      "comment" : "WatchOS indicator showing that watchOS can't auto-discover TV's due to network restrictions",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بالإضافة إلى ذلك، يمنعنا ووتش أو إس من اكتشاف التلفزيونات على الشبكة المحلية."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zusätzlich verhindert WatchOS, dass wir Fernseher im lokalen Netzwerk entdecken."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Además, WatchOS nos impide descubrir televisores en la red local."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Además, WatchOS nos impide descubrir televisores en la red local."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karagdagang, pinipigilan kami ng WatchOS sa pagtuklas ng mga TV sa lokal na network."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De plus, WatchOS nous empêche de découvrir des téléviseurs sur le réseau local."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De plus, WatchOS nous empêche de découvrir les téléviseurs sur le réseau local."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inoltre, WatchOS ci impedisce di scoprire le TV sulla rete locale."
          }
        },
        "pa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ਇਸ ਤੋਂ ਇਲਾਵਾ, WatchOS ਸਾਨੂੰ ਸਥਾਨਕ ਨੈੱਟਵਰਕ 'ਤੇ ਟੀਵੀ ਖੋਜਣ ਤੋਂ ਰੋਕਦਾ ਹੈ."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adicionalmente, o WatchOS nos impede de descobrir TVs na rede local."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adicionalmente, o WatchOS impede-nos de descobrir TVs na rede local."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thêm vào đó, WatchOS ngăn chúng tôi khám phá ra các TV trên mạng cục bộ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此外，WatchOS阻止我们在本地网络上发现电视。"
          }
        }
      }
    },
