          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mangyaring makipag-ugnayan sa roam-support@msd3.io upang matulungan ka naming mabawi ang iyong mga naka-save na device."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Veuillez contacter roam-support@msd3.io afin que nous puissions vous aider à récupérer vos appareils enregistrés."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Veuillez communiquer avec roam-support@msd3.io afin que nous puissions vous aider à récupérer vos appareils enregistrés."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contatta roam-support@msd3.io così possiamo aiutarti a recuperare i tuoi dispositivi salvati."
          }
        },
        "pa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ਕਿਰਪਾ ਕਰਕੇ roam-support@msd3.io ਨਾਲ ਸੰਪਰਕ ਕਰੋ ਤਾਂ ਜੋ ਅਸੀਂ ਤੁਹਾਡੇ ਸੇਵ ਕੀਤੇ ਡਿਵਾਈਸਾਂ ਨੂੰ ਮੁੜ ਪ੍ਰਾਪਤ ਕਰਨ ਵਿੱਚ ਮਦਦ ਕਰ ਸਕੀਏ।"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
