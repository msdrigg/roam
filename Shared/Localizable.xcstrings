    "Local network permission may not be granted. Please navigate to System Settings -> Apps -> Roam and enable Local Network" : {
      "comment" : "Warning indicator message that there is no local network permission",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قد لا يتم منح إذن الشبكة المحلية. يرجى التوجه إلى الإعدادات -> التطبيقات -> تجول وتفعيل الشبكة المحلية"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Berechtigung für das lokale Netzwerk ist möglicherweise nicht erteilt. Bitte navigieren Sie zu Systemeinstellungen -> Apps -> Roam und aktivieren Sie das lokale Netzwerk"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es posible que no se otorgue el permiso de red local. Por favor, navega a Configuración del sistema -> Aplicaciones -> Roam y habilita Red Local."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es posible que no se haya otorgado permiso para la red local. Navega a Configuración del Sistema -> Aplicaciones -> Roam y habilita la Red Local."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maaaring hindi maibigay ang pahintulot sa lokal na network. Mangyaring mag-navigate sa Mga Setting ng System -> Apps -> Roam at paganahin ang Lokal na Network"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'autorisation pour le réseau local peut ne pas être accordée. Veuillez naviguer vers Paramètres du système -> Applications -> Roam et activer Réseau local"
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il se peut que l'autorisation du réseau local ne soit pas accordée. Veuillez vous rendre dans Paramètres du système -> Applications -> Roam et activer Réseau local"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il permesso per la rete locale potrebbe non essere concesso. Si prega di navigare fino a Impostazioni Sistema -> App -> Roam e abilitare Rete Locale"
          }
        },
        "pa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'ਸਥਾਨਿਕ ਨੈਟਵਰਕ ਦੀ ਇਜਾਜ਼ਤ ਨਹੀਂ ਦਿੱਤੀ ਜਾ ਸਕਦੀ ਹੈ। ਕਿਰਪਾ ਕਰਕੇ ਸਿਸਟਮ ਸੈਟਿੰਗਜ਼ -> ਐਪਸ -> ਰੋਮ ਵੱਲ ਨੈਵੀਗੇਟ ਕਰੋ ਅਤੇ ਸਥਾਨਿਕ ਨੈਟਵਰਕ ਨੂੰ ਸੱਜੇ ਕਰੋ'"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A permissão para rede local pode não ter sido concedida. Por favor, navegue até Configurações do Sistema -> Aplicativos -> Roam e habilite a Rede Local."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A permissão de rede local pode não ser concedida. Por favor, navegue para Definições do Sistema -> Aplicações -> Roam e ative a Rede Local."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quyền truy cập mạng cục bộ có thể không được cấp. Vui lòng điều hướng đến Cài đặt hệ thống -> Ứng dụng -> Roam và bật Mạng cục bộ"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "可能未授予本地网络权限。请导航至系统设置 -> 应用程序 -> Roam并启用本地网络"
          }
        }
      }
    },
    "Local network permission may not be granted. Please open System Settings and navigate to Privacy and Security -> Local Network and enable access for Roam" : {
      "comment" : "Warning indicator message that there is no local network permission",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قد لا يتم منح إذن الشبكة المحلية. يرجى فتح إعدادات النظام والانتقال إلى الخصوصية والأمان -> الشبكة المحلية وتمكين الوصول لـ Roam."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Berechtigung für das lokale Netzwerk ist möglicherweise nicht erteilt. Bitte öffnen Sie die Systemeinstellungen und navigieren Sie zu Datenschutz und Sicherheit -> Lokales Netzwerk und aktivieren Sie den Zugriff für Roam."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es posible que no se haya concedido el permiso de red local. Por favor, abre Configuración del Sistema y navega a Privacidad y Seguridad -> Red Local y habilita el acceso para Roam."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es posible que no se haya otorgado el permiso de red local. Por favor, abre Configuración del sistema y ve a Privacidad y Seguridad -> Red Local y habilita el acceso para Roam."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ang pahintulot sa lokal na network ay maaaring hindi maibigay. Mangyaring buksan ang Mga Setting ng System at mag-navigate sa Privacy at Security -> Local Network at paganahin ang access para sa Roam."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il se peut que la permission du réseau local ne soit pas accordée. Veuillez ouvrir les Paramètres du Système et vous diriger vers Confidentialité et Sécurité -> Réseau Local et activer l'accès pour Roam."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'autorisation du réseau local pourrait ne pas être accordée. Veuillez ouvrir les paramètres du système et vous rendre dans Confidentialité et sécurité -> Réseau local et activer l'accès pour Roam."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Potrebbe non essere concessa l'autorizzazione per la rete locale. Si prega di aprire le Impostazioni di Sistema e navigare fino a Privacy e Sicurezza -> Rete Locale e abilitare l'accesso per Roam"
          }
        },
        "pa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'ਲੋਕਲ ਨੈਟਵਰਕ ਅਨੁਮਤੀ ਨਾ ਦਿੱਤੀ ਜਾਵੇ ਤੇ ਹੋ ਸਕਦਾ ਹੈ। ਕਿਰਪਾ ਕਰਕੇ ਸਿਸਟਮ ਸੈਟਿੰਗਜ਼ ਖੋਲ੍ਹੋ ਅਤੇ ਪ੍ਰਾਈਵੇਸੀ ਅਤੇ ਸੁਰੱਖਿਆ -> ਲੋਕਲ ਨੈਟਵਰਕ ਤੇ ਨੈਵੀਗੇਟ ਕਰੋ ਅਤੇ Roam ਲਈ ਐਕਸੈਸ ਯੋਗ ਕਰੋ'"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A permissão para rede local pode não estar concedida. Por favor, abra as Configurações do Sistema e vá até Privacidade e Segurança -> Rede Local e habilite o acesso para Roam."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A permissão para a rede local pode não ser concedida. Por favor, abra as Configurações do Sistema e navegue até Privacidade e Segurança -> Rede Local e ative o acesso ao Roam."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quyền truy cập mạng cục bộ có thể không được cấp. Vui lòng mở Cài đặt hệ thống và điều hướng đến Quyền riêng tư và Bảo mật -> Mạng cục bộ và kích hoạt quyền truy cập cho Roam"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "可能未授予本地网络权限。请打开系统设置，然后导航至隐私和安全 -> 本地网络，并为Roam启用访问权限。"
          }
        }
      }
    },
