          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Por favor, contacte roam-support@msd3.io para que possamos ajudar a recuperar os seus dispositivos guardados."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vui lòng liên hệ roam-support@msd3.io để chúng tôi có thể giúp khôi phục các thiết bị đã lưu của bạn."
