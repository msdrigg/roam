    "No valid WiFi connection detected. You may be connected to a hotspot instead of your home WiFi network" : {
      "comment" : "Warning indicator message that there is no WiFi network connection",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لم يتم اكتشاف اتصال WiFi صالح. قد تكون متصلاً بالهوت سبوت بدلاً من شبكة WiFi المنزلية الخاصة بك"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es wurde keine gültige WLAN-Verbindung erkannt. Sie sind möglicherweise mit einem Hotspot statt mit Ihrem Heim-WLAN-Netzwerk verbunden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se detectó una conexión WiFi válida. Es posible que estés conectado a un hotspot en lugar de a tu red WiFi de casa."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se detectó ninguna conexión WiFi válida. Es posible que estés conectado a un hotspot en lugar de tu red WiFi de casa."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Walang na-detect na wastong koneksyon sa WiFi. Maaring nakakonekta ka sa hotspot sa halip na sa iyong home WiFi network."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aucune connexion WiFi valide détectée. Vous êtes peut-être connecté à un hotspot au lieu de votre réseau WiFi domestique."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aucune connexion Wi-Fi valide détectée. Vous pouvez être connecté à un hotspot au lieu de votre réseau Wi-Fi domestique"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nessuna connessione WiFi valida rilevata. Potresti essere connesso a un hotspot invece che alla tua rete WiFi domestica."
          }
        },
        "pa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ਕੋਈ ਵੈਧ WiFi ਕਨੈਕਸ਼ਨ ਨਹੀਂ ਮਿਲਿਆ। ਤੁਸੀਂ ਆਪਣੇ ਘਰ ਦੇ WiFi ਨੈਟਵਰਕ ਦੀ ਬਜਾਏ ਹਾਟਸਪਾਟ ਨਾਲ ਜੋੜ ਸਕਦੇ ਹੋ।"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nenhuma conexão WiFi válida detectada. Você pode estar conectado a um hotspot em vez da sua rede WiFi doméstica."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nenhuma conexão WiFi válida detectada. Pode estar conectado a um hotspot em vez da sua rede WiFi doméstica."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Không phát hiện được kết nối WiFi hợp lệ. Bạn có thể đang kết nối với điểm phát sóng thay vì mạng WiFi nhà bạn"
          }
        },
        "zh-Hans" : {
