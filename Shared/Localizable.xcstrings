    "Click here to play your TV audio through your computer!" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انقر هنا لتشغيل صوت التلفزيون الخاص بك عبر الكمبيوتر الخاص بك!"
