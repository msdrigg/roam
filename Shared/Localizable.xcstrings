    "Check the IP address you entered is correct, and ensure that you and the device are connected to the same WiFi network" : {
      "comment" : "Recovery suggestion for device not found",
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تأكد من أن عنوان ال IP الذي أدخلته صحيح ، وتأكد من أنك والجهاز متصلين بنفس شبكة ال WiFi"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Überprüfen Sie, ob die eingegebene IP-Adresse korrekt ist und stellen Sie sicher, dass Sie und das Gerät mit demselben WiFi-Netzwerk verbunden sind."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verifique que la dirección IP que ingresó sea correcta y asegúrese de que usted y el dispositivo estén conectados a la misma red WiFi"
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verifica que la dirección IP que ingresaste sea correcta, y asegúrate de que tú y el dispositivo estén conectados a la misma red WiFi."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suriin kung tama ang IP address na iyong naipasok, at siguraduhing ikaw at ang device ay konektado sa parehong WiFi network"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vérifiez que l'adresse IP que vous avez saisie est correcte et assurez-vous que vous et l'appareil êtes connectés au même réseau WiFi"
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vérifiez que l'adresse IP que vous avez saisie est correcte et assurez-vous que vous et l'appareil êtes connectés au même réseau WiFi"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Controlla che l'indirizzo IP che hai inserito sia corretto e assicurati che tu e il dispositivo siate connessi alla stessa rete WiFi"
          }
        },
        "pa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ਕਿਰਪਾ ਕਰਕੇ ਜਾਂਚੋ ਕਿ ਤੁਸੀਂ ਦਿੱਤੇ ਗਏ IP ਪਤੇ ਸਹੀ ਹਨ ਅਤੇ ਯਕੀਨੀ ਬਣਾਓ ਕਿ ਤੁਸੀਂ ਅਤੇ ਡਿਵਾਈਸ ਇਕੋ ਵਾਈਫਾਈ ਨੈੱਟਵਰਕ ਨਾਲ ਜੁੜੇ ਹੋਏ ਹੋ।"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verifique se o endereço IP que você inseriu está correto e certifique-se de que você e o dispositivo estão conectados à mesma rede WiFi"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verifique se o endereço IP que inseriu está correto e certifique-se de que você e o dispositivo estão conectados à mesma rede WiFi"
          }
