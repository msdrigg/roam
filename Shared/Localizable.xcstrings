    "If Roam isn't auto-discovering your tv, check this guide to manually add your TV: https://roam.msd3.io/manually-add-tv/" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا لم يتمكن Roam من العثور على التلفزيون الخاص بك تلقائيًا، فقم بالرجوع إلى هذا الدليل لإضافة التلفزيون الخاص بك يدويًا: https://roam.msd3.io/ar/manually-add-tv/"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Roam Ihren Fernseher nicht automatisch erkennt, überprüfen Sie diesen Leitfaden, um Ihren Fernseher manuell hinzuzufügen: https://roam.msd3.io/de/manually-add-tv/"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si Roam no está descubriendo automáticamente tu televisor, consulta esta guía para agregar manualmente tu TV: https://roam.msd3.io/es/manually-add-tv/"
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si Roam no está descubriendo automáticamente tu televisor, consulta esta guía para agregar manualmente tu TV: https://roam.msd3.io/es-419/manually-add-tv/"
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kung hindi awtomatikong natutuklasan ng Roam ang iyong tv, suriin ang gabay na ito para manu-manong idagdag ang iyong TV: https://roam.msd3.io/fil/manually-add-tv/"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si Roam ne découvre pas automatiquement votre télévision, consultez ce guide pour ajouter manuellement votre télévision : https://roam.msd3.io/fr/manually-add-tv/"
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si Roam ne découvre pas automatiquement votre téléviseur, consultez ce guide pour ajouter manuellement votre téléviseur : https://roam.msd3.io/fr-CA/manually-add-tv/"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se Roam non sta scoprendo automaticamente la tua TV, controlla questa guida per aggiungere manualmente la tua TV: https://roam.msd3.io/it/manually-add-tv/"
          }
        },
        "pa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ਜੇ Roam ਤੁਹਾਡੇ TV ਨੂੰ ਆਪਣੇ ਆਪ ਨਹੀਂ ਖੋਜ ਰਿਹਾ ਹੈ, ਤਾਂ ਆਪਣੇ TV ਨੂੰ ਮੈਨੁਅਲ ਤੌਰ 'ਤੇ ਸ਼ਾਮਲ ਕਰਨ ਲਈ ਇਸ ਗਾਈਡ ਨੂੰ ਚੈੱਕ ਕਰੋ: https://roam.msd3.io/pa/manually-add-tv/"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se o Roam não está descobrindo automaticamente sua televisão, verifique este guia para adicionar manualmente sua TV: https://roam.msd3.io/pt-BR/manually-add-tv/"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se o Roam não está a descobrir automaticamente a sua TV, consulte este guia para adicionar manualmente a sua TV: https://roam.msd3.io/pt-PT/manually-add-tv/"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nếu Roam không tự động phát hiện tivi của bạn, hãy kiểm tra hướng dẫn này để thêm tivi của bạn một cách thủ công: https://roam.msd3.io/vi/manually-add-tv/"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果Roam未能自动发现您的电视，请查阅此指南手动添加您的电视：https://roam.msd3.io/zh-Hans/manually-add-tv/"
          }
        }
      }
